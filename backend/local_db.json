  "profiles": [
    {
      "id": "e4c44972-b788-45cc-96a6-134f0982ddb1",
      "display_name": "Ramesh Kumar",
      "email": "artisan1@artisan.com",
      "bio": "Hailing from Saharanpur, I carry forward a 300-year-old family legacy of fine woodcraft, carving intricate traditional and modern designs from sustainable local timber.",
      "photo_url": "https://images.unsplash.com/photo-1542330952650-efce130ebc18?w=400",
      "location": "Saharanpur",
      "followers": [],
      "following": [],
      "wishlist": [],
      "created_at": "2026-06-16T17:02:10.107Z",
