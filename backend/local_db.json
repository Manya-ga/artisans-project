    },
    {
      "id": "70b4a4f4-47c7-4445-9006-a350c73d4745",
      "display_name": "Lakshmi Devi",
      "email": "artisan2@artisan.com",
      "bio": "I paint ancient mythologies using natural pigments sourced from soot, turmeric, and indigo. Every brushstroke preserves the rich cultural heritage of Bihar.",
      "photo_url": "https://images.unsplash.com/photo-1595085610896-bc316fb01b8e?w=400",
      "location": "Madhubani",
      "followers": [],
      "following": [],
      "wishlist": [],
      "created_at": "2026-06-16T17:02:10.107Z",
      "updated_at": "2026-06-16T17:02:10.107Z"
    },
    {
      "id": "fbbd2567-8747-4237-a71c-c2e81b955074",
      "display_name": "Anjali Verma",
      "email": "artisan3@artisan.com",
      "bio": "Specializing in Chikankari and Phulkari, my craft involves delicate hand-embroidery that breathes life into fabric, a skill passed down from my grandmother.",
      "photo_url": "https://images.unsplash.com/photo-1591851221711-50e4179d6756?w=400",
      "location": "Lucknow",
      "followers": [],
      "following": [],
      "wishlist": [],
      "created_at": "2026-06-16T17:02:10.107Z",
      "updated_at": "2026-06-16T17:02:10.107Z"
    },
    {
      "id": "830bf521-16a0-4e28-95e8-5a9d34135643",
      "display_name": "Shankar Rao",
      "email": "artisan4@artisan.com",
      "bio": "Using pure riverbank clay, I hand-shape and kiln-fire traditional terracotta planters, sculptures, and diyas that connect homes back to nature.",
      "photo_url": "https://images.unsplash.com/photo-1555529902-5261145633bf?w=400",
      "location": "Karnataka",
      "followers": [],
      "following": [],
      "wishlist": [],
      "created_at": "2026-06-16T17:02:10.107Z",
      "updated_at": "2026-06-16T17:02:10.107Z"
    },
    {
      "id": "37d09f0a-c941-4ded-bdae-3b0e43d8ea5f",
      "display_name": "Meera Patel",
      "email": "artisan5@artisan.com",
      "bio": "I craft vibrant, authentic handloom textiles. My work involves traditional pit-loom weaving to create ethical and sustainable Indian fashion.",
      "photo_url": "https://images.unsplash.com/photo-1589156229687-496a31ad1d1f?w=400",
      "location": "Gujarat",
      "followers": [],
      "following": [],
