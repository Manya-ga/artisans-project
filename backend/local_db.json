    },
    {
      "id": "2fa294cd-9040-4f63-9c80-7b4ca0b13d83",
      "display_name": "Sunita Kumari",
      "email": "artisan9@artisan.com",
      "bio": "I weave natural fibers into durable, beautiful baskets, mats, and bags. My craft supports local women's cooperatives in rural Bengal.",
      "photo_url": "https://images.unsplash.com/photo-1571210986790-2c7cc1e9dbdc?w=400",
      "location": "West Bengal",
      "followers": [],
      "following": [],
