    {
      "id": "41013bc7-437c-4ad1-8068-c6642fac0c40",
      "display_name": "Harish Joshi",
      "email": "artisan8@artisan.com",
      "bio": "From traditional oil lamps to ornate idols, I practice sand casting and hand-engraving brass and bell metal, techniques native to the 'Brass City' of India.",
      "photo_url": "https://images.unsplash.com/photo-1546961342-9957252cb7ec?w=400",
      "location": "Moradabad",
      "followers": [],
      "following": [],
      "wishlist": [],
