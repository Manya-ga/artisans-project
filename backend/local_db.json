    },
    {
      "id": "b11e53ff-601c-4d36-bcd3-2127ddb317f5",
      "display_name": "Ravi Choudhary",
      "email": "artisan6@artisan.com",
      "bio": "Unlike standard ceramics, my pottery uses quartz stone powder instead of clay. It's a challenging, painstaking process that yields brilliant, unfading blue art.",
      "photo_url": "https://images.unsplash.com/photo-1603415526960-f7e0328c63b1?w=400",
      "location": "Jaipur",
      "followers": [],
      "following": [],
