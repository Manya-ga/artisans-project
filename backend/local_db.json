    },
    {
      "id": "81bccac3-2731-47fa-b823-60d08a8e253b",
      "display_name": "Kavitha Nair",
      "email": "artisan7@artisan.com",
      "bio": "I transform locally sourced bamboo into elegant, sustainable furniture, lampshades, and baskets. My craft reflects the harmony of nature and utility.",
      "photo_url": "https://images.unsplash.com/photo-1506869640319-fea1a2ab8e9c?w=400",
      "location": "Assam",
      "followers": [],
      "following": [],
